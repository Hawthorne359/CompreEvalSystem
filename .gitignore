# ── 环境变量（绝不提交到 Git！）──────────────────────────────
.env
.env.local
.env.production

# ── 内部开发文档（仅供开发者参考，不对外公开）──────────────────
docs/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── 虚拟环境 ─────────────────────────────────────────────────
.venv/
venv/
env/

# ── Django 运行时目录（服务器上生成，不纳入版本控制）──────────
staticfiles/
media/
logs/
cache/

# ── 数据库文件 ───────────────────────────────────────────────
*.sqlite3
*.db
*.sql

# ── 归档目录（废弃模块存放处）────────────────────────────────
_archive/

# ── 前端构建产物 ─────────────────────────────────────────────
frontend/dist/
frontend/node_modules/

# ── 包管理器锁文件（uv 专用，不影响他人复现环境）──────────────
uv.lock
pyproject.toml

# ── 开发辅助脚本（仅本地使用）────────────────────────────────
student-mobile-test/

# ── IDE / 编辑器 ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── 系统 ─────────────────────────────────────────────────────
*.log
*.pid
