# ============================================================
# CompreEvalSystem 环境变量配置模板
# 复制本文件为 .env，填入实际值后启动项目
# .env 文件已加入 .gitignore，不会提交到 Git
# ============================================================

# ── 核心安全 ─────────────────────────────────────────────────
# 生产环境必须替换为强随机密钥，可用以下命令生成：
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=django-insecure-change-me-in-production

# 开发环境设 True；生产环境必须设 False
DJANGO_DEBUG=True

# 允许访问的主机，多个用英文逗号分隔（不带空格）
# 生产示例：DJANGO_ALLOWED_HOSTS=54.123.45.67,your-domain.com,localhost
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── 数据库 ──────────────────────────────────────────────────
DB_NAME=campus_eval
DB_USER=root
DB_PASSWORD=123456
DB_HOST=127.0.0.1
DB_PORT=3306

# ── Docker MySQL 初始化专用（docker-compose 使用）────────────
# 仅在使用 docker-compose 部署时需要填写；手动部署可忽略
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=campus_eval

# ── 媒体文件存储路径 ─────────────────────────────────────────
# 用户上传文件的根目录。
# 留空 → 默认使用项目根目录下的 media/ 文件夹
# 可填绝对路径，例如：MEDIA_ROOT=/data/uploads
# Docker 部署时留空，挂载卷由 docker-compose.yml 管理
MEDIA_ROOT=

# ── CORS 跨域 ────────────────────────────────────────────────
# 开发环境设 True（允许所有来源）；生产必须设 False
CORS_ALLOW_ALL_ORIGINS=True
# CORS_ALLOW_ALL_ORIGINS=False 时生效，多个用英文逗号分隔
# 示例：CORS_ALLOWED_ORIGINS=http://54.123.45.67,https://your-domain.com
CORS_ALLOWED_ORIGINS=

# ── 缓存后端 ─────────────────────────────────────────────────
# file  → 文件缓存（默认，无需额外依赖，适合单机部署）
# redis → Redis 缓存（需要 Redis 服务，适合高并发生产环境）
CACHE_BACKEND=file

# CACHE_BACKEND=file 时：缓存目录（留空使用项目根目录下 cache/）
CACHE_LOCATION=

# CACHE_BACKEND=redis 时：Redis 连接 URL
CACHE_REDIS_URL=redis://127.0.0.1:6379/1

# ── 日志目录 ─────────────────────────────────────────────────
# 留空 → 默认使用项目根目录下的 logs/ 文件夹
# 可填绝对路径，例如：LOG_DIR=/var/log/compre-eval
LOG_DIR=

# ── 未来扩展：对象存储（当前未启用）────────────────────────
# 若将来需要接入 AWS S3 / 阿里云 OSS 等对象存储，
# 取消下方注释并安装对应的 django-storages 后端
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=

# ── Docker 镜像名（生产服务器拉取镜像时使用）────────────────
# 格式：你的DockerHub用户名/镜像名:标签
# 示例：IMAGE_NAME=zhangsan/compre-eval-backend:latest
# 本地开发留空即可，compose 会自动用 build 指令构建本地镜像
IMAGE_NAME=
